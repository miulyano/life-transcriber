BOT_TOKEN=your_telegram_bot_token_here
OPENAI_API_KEY=sk-your_openai_api_key_here
# AssemblyAI (transcription + acoustic speaker diarization)
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here
# Comma-separated Telegram user IDs allowed to use the bot
ALLOWED_USER_IDS=123456789,987654321
# Optional overrides
LONG_TEXT_THRESHOLD=2000
ASSEMBLYAI_SPEECH_MODEL=universal
GPT_MODEL=gpt-4o
TEMP_DIR=/tmp/transcriber
# Word boost — bias recognition toward domain terms (one per line, # for comments).
WORD_BOOST_FILE=bot/data/word_boost.txt
WORD_BOOST_LEVEL=high
# Custom spelling — post-process replacements (JSON object {"recognized": "preferred"}).
CUSTOM_SPELLING_FILE=bot/data/custom_spelling.json
# Force a specific language (e.g. "ru") instead of autodetect — recommended
# only if all your audio is the same known language.
FORCE_LANGUAGE_CODE=
# Cobalt API for Instagram video downloads (default: http://cobalt:9000)
COBALT_API_URL=http://cobalt:9000
# Optional Instagram cookies JSON for bot fallback when Cobalt cannot resolve media
INSTAGRAM_COOKIES_PATH=
# Optional yt-dlp proxy. Use YANDEX_MUSIC_PROXY for Yandex Music only when VPS
# region is blocked by HTTP 451, e.g. socks5://user:pass@host:1080
YTDLP_PROXY=
YANDEX_MUSIC_PROXY=
# Mini App — file upload via Telegram WebView (bypasses 20 MB Bot API limit)
# Set to your public HTTPS URL to enable the "📤 Загрузить файл" menu button.
# The webapp service must be accessible via shared Caddy on VPS (see README).
WEBAPP_URL=https://transcriber.example.com

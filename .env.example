BOT_TOKEN=your_telegram_bot_token_here
OPENAI_API_KEY=sk-your_openai_api_key_here
# Comma-separated Telegram user IDs allowed to use the bot
ALLOWED_USER_IDS=123456789,987654321
# Optional overrides
LONG_TEXT_THRESHOLD=2000
WHISPER_MODEL=whisper-1
GPT_MODEL=gpt-4o
TEMP_DIR=/tmp/transcriber
# Local Bot API — снимает лимит 20 MB → ~2 GB на скачивание файлов.
# Получить api_id и api_hash: https://my.telegram.org/auth → API development tools → Create application
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_API_URL=http://tg-api:8081
